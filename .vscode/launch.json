{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (open ApiHelper as workspace root)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"]
    },
    {
      "name": "Run Extension (retail-node-ump monorepo root)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/ApiHelper"],
      "outFiles": ["${workspaceFolder}/ApiHelper/out/**/*.js"]
    }
  ]
}
